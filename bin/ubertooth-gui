#!/bin/bash
# ubertooth-gui - Graphical menu for Ubertooth tools using Zenity
# Run this for a point-and-click interface instead of typing commands.
# Long-running captures are launched in a separate terminal (which stays open).

set -o pipefail

# Ensure zenity is available. If missing, launch a terminal to install it
# (important because the GUI desktop may start with no visible terminal).
if ! command -v zenity >/dev/null 2>&1; then
    echo "Zenity not found - installing now..."
    # Use pkexec for graphical password prompt if possible (works even when launched without terminal)
    if command -v pkexec >/dev/null 2>&1; then
        pkexec apt update && pkexec apt install -y zenity || {
            # fallback to terminal if pkexec fails
            /usr/share/kali-menu/exec-in-shell "echo 'Installing zenity for Ubertooth GUI...'; sudo apt update && sudo apt install -y zenity && echo 'Done. Re-launch the GUI now.'" > /dev/null 2>&1 &
            if command -v notify-send >/dev/null 2>&1; then
                notify-send "Ubertooth GUI" "Installing zenity. A terminal or auth dialog should appear for the password.\nRe-launch after it completes."
            fi
            exit 0
        }
    else
        # no pkexec, use terminal
        /usr/share/kali-menu/exec-in-shell "echo 'Installing zenity for Ubertooth GUI...'; sudo apt update && sudo apt install -y zenity && echo 'Done. You can now re-launch Ubertooth GUI from the menu.'" > /dev/null 2>&1 &
        if command -v notify-send >/dev/null 2>&1; then
            notify-send "Ubertooth GUI" "Zenity is being installed. Check for a terminal or auth prompt.\nRe-launch the GUI after it finishes."
        fi
        exit 0
    fi
    # if we reach here, zenity should now be installed, re-exec to start the GUI
    exec "$0" "$@"
fi

# Helper: launch a command in a persistent *visible* terminal window.
# We explicitly use a terminal emulator so that when this GUI (zenity) launches
# actions like scan/prepare/status-output, the user actually sees a window
# with the ubertooth command running and can interact (e.g. sudo prompts, Ctrl-C).
# The old kali wrapper alone doesn't reliably create a visible window when
# called from a backgrounded GUI process.
# keep_open: if false (for prepare), run cmd then auto-close the terminal window.
launch_in_terminal() {
    local user_cmd="$1"
    local keep_open="${2:-true}"
    if [ -z "$user_cmd" ]; then
        zenity --error --text="No command specified."
        return 1
    fi

    # Use a temp script file for the actual work (diagnostics + the command).
    # This avoids all quoting problems with complex $user_cmd (single quotes etc. from scan diagnostics).
    # The launcher wrapper below (bash -c) controls whether the terminal stays open or closes.
    local tmp_script="/tmp/uber-cmd-$$-$RANDOM.sh"
    {
        echo '#!/bin/bash'
        echo 'echo "=== Ubertooth command ==="'
        printf 'echo " $ %s"\n' "$user_cmd"
        echo 'echo "========================="'
        printf '%s\n' "$user_cmd"
        echo 'echo ""'
    } > "$tmp_script"
    chmod +x "$tmp_script"

    # Build a safe quoted path for embedding in the -c string.
    local qscript
    qscript=$(printf '%q' "$tmp_script")

    local term_cmd=""
    if command -v x-terminal-emulator >/dev/null 2>&1; then
        if [ "$keep_open" = "true" ]; then
            # Pass as a single argument to -e:  "bash -c ' script ; ... ; exec bash -i ' "
            # This is more reliable with qterminal (and others) than splitting -e bash -c ...
            term_cmd="x-terminal-emulator -e \"bash -c ' ${qscript} ; rm -f ${qscript} ; echo \\\"=== Command finished ===\\\"; echo \\\"This terminal stays open. You can run more ubertooth commands here or type exit.\\\"; exec bash -i ' \" "
        else
            term_cmd="x-terminal-emulator -e \"bash -c ' ${qscript} ; rm -f ${qscript} ; echo \\\"=== Done - terminal will close automatically ===\\\"; sleep 2 ' \" "
        fi
    elif command -v gnome-terminal >/dev/null 2>&1; then
        if [ "$keep_open" = "true" ]; then
            term_cmd="gnome-terminal -- bash -c ' ${qscript} ; rm -f ${qscript} ; echo \"=== Command finished ===\"; echo \"This terminal stays open. You can run more ubertooth commands here or type exit.\"; exec bash -i ' "
        else
            term_cmd="gnome-terminal -- bash -c ' ${qscript} ; rm -f ${qscript} ; echo \"=== Done - terminal will close automatically ===\"; sleep 2 ' "
        fi
    elif command -v konsole >/dev/null 2>&1; then
        if [ "$keep_open" = "true" ]; then
            term_cmd="konsole -e \"bash -c ' ${qscript} ; rm -f ${qscript} ; echo \\\"=== Command finished ===\\\"; echo \\\"This terminal stays open...\\\"; exec bash -i ' \" "
        else
            term_cmd="konsole -e \"bash -c ' ${qscript} ; rm -f ${qscript} ; echo \\\"=== Done - terminal will close automatically ===\\\"; sleep 2 ' \" "
        fi
    else
        # Last resort fallback
        /usr/share/kali-menu/exec-in-shell "$tmp_script" > /dev/null 2>&1 &
        term_cmd=""
    fi

    if [ -n "$term_cmd" ]; then
        eval "$term_cmd" > /dev/null 2>&1 &
    fi

    # Notification (uses the original user_cmd text)
    if command -v notify-send >/dev/null 2>&1; then
        if [ "$keep_open" = "true" ]; then
            notify-send "Ubertooth" "Launched in terminal window:\n$user_cmd\n\nLook for the new terminal that just opened.\nIt will stay open with a shell after the command ends."
        else
            notify-send "Ubertooth" "Preparation running in terminal:\n$user_cmd\n\nThe prep terminal will close automatically when done."
        fi
    else
        if [ "$keep_open" = "true" ]; then
            zenity --info --timeout=4 --title="Launched in terminal" --text="A terminal window should have opened for:\n$user_cmd\n\nWatch it for output (sudo prompts, scan results, etc.).\nClose it when done." 2>/dev/null || true
        fi
    fi
}

# Show device status in a text dialog
show_status() {
    local output
    output=$(
        echo "=== Ubertooth Device Status ==="
        echo "Detected devices: $(ubertooth-util -N 2>/dev/null || echo 0)"
        echo
        ubertooth-util -v 2>&1 || true
        echo
        ubertooth-util -V 2>&1 || true
        echo
        ubertooth-util -b 2>&1 || true
        ubertooth-util -s 2>&1 || true
        echo
        echo "LED status etc. available via other menu items."
    )
    zenity --text-info --title="Ubertooth Status" --width=650 --height=420 \
        --filename=<(echo "$output") --ok-label="Close"
}

do_identify() {
    zenity --info --title="Identify" --text="The LEDs on the Ubertooth dongle should now blink to help you identify it."
    launch_in_terminal "ubertooth-util -I"
}

do_reset() {
    if zenity --question --title="Reset Device" --text="Really send a full reset to the Ubertooth device?"; then
        launch_in_terminal "ubertooth-util -r"
    fi
}

do_prepare() {
    local msg="This will help 'bring up' the Ubertooth One for use:\n\n"
    msg+="• Reset the dongle (ubertooth-util -r)\n"
    msg+="• Activate exclusive USB access via Sniffer USB Manager (unbinds kernel btusb driver so ubertooth-* tools own it)\n"
    msg+="• Bring UP any DOWN hci adapters (needed only for classic ubertooth-scan)\n\n"
    msg+="This may prompt for your password (pkexec/sudo) for USB and adapter changes.\n\nRun preparation now?"

    if ! zenity --question --title="Prepare Ubertooth One" --text="$msg" --width=520; then
        return
    fi

    # Write a temp prep script (avoids horrible quoting). It will be cleaned on exit of that shell.
    # Now: auto-installs passwordless sudo via graphical pkexec (so no password typing in terminal),
    # then runs unbind + hci bring-up. The launch for prepare will auto-close the terminal.
    local tmp_prep="/tmp/ubertooth-prep-$$.sh"
    cat > "$tmp_prep" << 'PREP_EOF'
#!/bin/bash
echo '=== 0. Ensuring passwordless sudo for Sniffer USB ops (graphical auth if needed) ==='
echo '   (This lets the rest of prep run without terminal password prompts.)'
pkexec /home/will/bin/sniffer-usb-manager/priv-helper.sh install-sudoers 2>&1 || true
echo
echo '=== 0b. Also making hciconfig passwordless (so future bring-ups need no prompts) ==='
REALU=$(id -un 2>/dev/null || echo "$USER")
pkexec bash -c '
  RULE="/etc/sudoers.d/ubertooth-hci"
  if ! grep -q "hciconfig" "$RULE" 2>/dev/null; then
    echo "'"$REALU"' ALL=(root) NOPASSWD: /usr/bin/hciconfig" >> "$RULE" 2>/dev/null || true
    chmod 0440 "$RULE" 2>/dev/null || true
    visudo -c -f "$RULE" >/dev/null 2>&1 || rm -f "$RULE"
  fi
' 2>&1 || true
echo
echo '=== 1. Resetting Ubertooth One ==='
ubertooth-util -r 2>&1 || true
echo
echo '=== 2. Current device detection ==='
ubertooth-util -N -v -V -s 2>&1 || true
echo
echo '=== 3. Activating Ubertooth exclusive mode (via Sniffer USB Manager) ==='
MGR=""
for cand in /home/will/bin/sniffer-usb-manager/launch.sh \
            $(command -v sniffer-usb-manager 2>/dev/null || true) \
            /usr/local/bin/sniffer-usb-manager; do
    if [ -x "$cand" ] || [ -x "$(dirname "$cand" 2>/dev/null)/launch.sh" ]; then
        MGR="$cand"
        break
    fi
done
if [ -n "$MGR" ]; then
    (cd "$(dirname "$MGR" 2>/dev/null || echo .)" && ./launch.sh --ubertooth) 2>&1 || "$MGR" --ubertooth 2>&1 || true
else
    echo 'Sniffer USB Manager not found. Launch it from Desktop/Kali menu and use "Activate Ubertooth One".'
fi
echo
echo '=== 4. Bringing up any DOWN hci adapters (for ubertooth-scan classic) ==='
for dev in $(hciconfig 2>/dev/null | grep -o '^hci[0-9]' | tr -d ':'); do
    state=$(hciconfig "$dev" 2>/dev/null | grep -E 'UP|DOWN' | head -1)
    echo "$dev current state: $state"
    if echo "$state" | grep -qi DOWN; then
        echo "Bringing $dev UP..."
        # Prefer pkexec (graphical password dialog, no terminal typing)
        pkexec hciconfig "$dev" up 2>/dev/null || sudo -n hciconfig "$dev" up 2>/dev/null || echo "Failed to up $dev (try manually or ensure sudoers)"
    fi
    echo "Enabling piscan (page/inquiry scan) on $dev to help ubertooth-scan inquiry..."
    hciconfig "$dev" piscan 2>/dev/null || sudo -n hciconfig "$dev" piscan 2>/dev/null || true
done
echo
echo '=== 5. Final hci status ==='
hciconfig 2>/dev/null || true
echo
echo '=== Preparation complete. ==='
echo 'Terminal will close automatically. Return to the Ubertooth GUI and choose Status to verify.'
rm -f "$0"   # self-clean the temp script
PREP_EOF
    chmod +x "$tmp_prep"

    launch_in_terminal "$tmp_prep" false

    zenity --info --title="Preparation launched" \
        --text="A terminal window was opened with the preparation steps (it will auto-close when done).\n\nOne graphical password prompt may appear for the one-time passwordless sudo setup.\n\nAfter the prep terminal disappears, use the 'status' item in the main menu to confirm Ubertooth is detected and adapters are UP." --width=520
}

do_scan() {
    # Check for Ubertooth hardware (required for ubertooth-scan to do the Ubertooth part)
    local udev_count
    udev_count=$(ubertooth-util -N 2>/dev/null | tr -cd '0-9' || echo 0)
    [ -z "$udev_count" ] && udev_count=0

    # Robust check for any UP classic BT adapter (hci "UP" or "UP RUNNING" can be on its own line)
    local has_up
    has_up=$(hciconfig 2>/dev/null | grep -i 'UP' || true)

    if [ "$udev_count" -lt 1 ]; then
        if ! zenity --question --title="Classic Bluetooth Scan" \
            --text="No Ubertooth device detected (ubertooth-util -N = $udev_count).\n\nUbertooth One must be plugged in and powered for ubertooth-scan.\n\nProceed with scan anyway (will likely fail)?"; then
            return
        fi
    fi

    if [ -z "$has_up" ]; then
        # Find a down adapter using reliable per-device check (same logic as startup/prepare)
        local down_hci=""
        for d in $(hciconfig 2>/dev/null | grep -o '^hci[0-9]' | tr -d ':'); do
            if hciconfig "$d" 2>/dev/null | grep -qi DOWN; then
                down_hci="$d"
                break
            fi
        done

        if [ -n "$down_hci" ]; then
            # Auto-attempt bring-up when user chooses scan.
            # pkexec will show a graphical auth dialog if needed (and block until done/cancel).
            # This is the "embedded" automatic bring-up at the point of use.
            # Falls back gracefully.
            if command -v pkexec >/dev/null 2>&1; then
                pkexec hciconfig "$down_hci" up 2>/dev/null || true
            else
                sudo -n hciconfig "$down_hci" up 2>/dev/null || launch_in_terminal "sudo hciconfig $down_hci up" || true
            fi
            sleep 1
            has_up=$(hciconfig 2>/dev/null | grep -i 'UP' || true)
        fi
    fi

    if [ -z "$has_up" ]; then
        # Still no UP after the automatic bring-up attempt above.
        # Show a non-blocking warning (no "Launch the scan anyway?" yes/no question that you keep seeing).
        # Then always proceed to the duration entry (user can cancel there if they really don't want to try).
        # This is the main fix so the UTI on the menu doesn't nag you with that exact dialog when the dongle is detected but hci is just down.
        local hci_state
        hci_state=$(hciconfig 2>/dev/null | grep -E '^hci[0-9]' -A 3 || echo "(no hci adapters found)")

        zenity --warning --title="Classic Bluetooth Scan - adapter down" \
            --text="Ubertooth One detected: $udev_count\n\nNo active (UP) Bluetooth adapter detected (after auto bring-up attempt).\n\nhci state:\n$hci_state\n\nThe ubertooth-scan tool requires a working BT adapter (for inquiry scans) + the Ubertooth dongle.\n\nIt will likely fail with 'Unable to find hci0'.\n\nProceeding to the duration prompt anyway — you can cancel if you want." --timeout=5 || true
    fi

    local duration
    duration=$(zenity --entry --title="Classic Scan" --text="Scan duration in seconds:" --entry-text="20")
    [ -z "$duration" ] && duration=20

    # Build a robust command that always specifies the Ubertooth (-U 0) and hci adapter (-b hci0)
    # and includes pre-flight diagnostics so you can see if the adapter/dongle are recognized
    # when the terminal opens. This helps when you run scan without prepare first, or after prepare.
    local base="ubertooth-scan -b hci0 -U 0 -t $duration"
    local cmd="echo '=== Pre-scan diagnostics ==='; hciconfig -a 2>&1 || true; echo '---'; hcitool dev 2>&1 || true; echo '--- Ubertooth devices ---'; ubertooth-util -N -v 2>&1 || true; echo '--- Starting scan ---'; $base"
    if zenity --question --title="Extended Scan" --text="Also perform BlueZ + extended inquiry scan (-s -x)?"; then
        cmd="$cmd -s -x"
    fi
    launch_in_terminal "$cmd"
}

do_ble_adv() {
    local file
    file=$(zenity --file-selection --save --confirm-overwrite \
        --filename="/tmp/ble-advertisements.pcapng" \
        --title="Capture file (Cancel = live only, no capture)" 2>/dev/null || true)

    local cmd="ubertooth-btle -n"
    if [ -n "$file" ]; then
        cmd="$cmd -r '$file'"
    fi
    launch_in_terminal "$cmd"
}

do_ble_follow() {
    local mode
    mode=$(zenity --list --title="BLE Mode" --text="Choose monitoring mode" \
        --column="Mode" --column="Description" --width=500 --height=200 \
        "adv"     "Advertisements only (passive, no connection follow)" \
        "follow"  "Follow specific connection (enter address below)" \
        "prom"    "Promiscuous - try to follow all active connections" \
        2>/dev/null || true)
    [ -z "$mode" ] && return

    local cmd="ubertooth-btle"
    local addr=""

    case "$mode" in
        adv)
            cmd="$cmd -n"
            ;;
        follow)
            addr=$(zenity --entry --title="Target Address" \
                --text="Target Bluetooth address (example: 22:44:66:88:aa:cc)\nLeave empty to follow any:" --entry-text="")
            cmd="$cmd -f"
            if [ -n "$addr" ]; then
                cmd="$cmd -t '$addr'"
            fi
            ;;
        prom)
            cmd="$cmd -p"
            ;;
    esac

    local file
    file=$(zenity --file-selection --save --confirm-overwrite \
        --filename="/tmp/ble-follow.pcapng" \
        --title="Optional PCAPNG capture file (Cancel = no file capture)" 2>/dev/null || true)
    if [ -n "$file" ]; then
        cmd="$cmd -r '$file'"
    fi

    launch_in_terminal "$cmd"
}

do_classic_rx() {
    local mode
    mode=$(zenity --list --title="Classic RX Mode" \
        --column="Mode" --column="Description" --width=520 --height=180 \
        "all"     "Sniff / discover all LAPs (default)" \
        "survey"  "Survey mode: discover LAP + UAP (timed)" \
        "specific" "Target specific LAP (and optional UAP)" \
        2>/dev/null || true)
    [ -z "$mode" ] && return

    local cmd="ubertooth-rx"
    case "$mode" in
        survey)
            local secs
            secs=$(zenity --entry --title="Survey Time" --text="How many seconds to survey?" --entry-text="30")
            [ -z "$secs" ] && secs=30
            cmd="$cmd -z -t $secs"
            ;;
        specific)
            local lap
            lap=$(zenity --entry --title="LAP" --text="LAP (6 hex digits, e.g. 446688):" --entry-text="")
            if [ -n "$lap" ]; then
                cmd="$cmd -l $lap"
                local uap
                uap=$(zenity --entry --title="UAP (optional)" --text="UAP (2 hex digits, e.g. 22):" --entry-text="")
                if [ -n "$uap" ]; then
                    cmd="$cmd -u $uap"
                fi
            fi
            ;;
        *)
            # all LAPs - default
            ;;
    esac

    local file
    file=$(zenity --file-selection --save --confirm-overwrite \
        --filename="/tmp/classic-rx.pcapng" \
        --title="Optional PCAPNG file (Cancel = live only)" 2>/dev/null || true)
    if [ -n "$file" ]; then
        cmd="$cmd -r '$file'"
    fi

    launch_in_terminal "$cmd"
}

do_capture() {
    local captype
    captype=$(zenity --list --title="Capture Type" \
        --column="Type" --column="Tool / Notes" --width=500 --height=160 \
        "ble"     "BLE (Low Energy) - ubertooth-btle" \
        "classic" "Classic Bluetooth - ubertooth-rx" \
        2>/dev/null || true)
    [ -z "$captype" ] && return

    local file
    file=$(zenity --file-selection --save --confirm-overwrite \
        --filename="/tmp/ubertooth-capture.pcapng" \
        --title="Save capture to PCAPNG file" 2>/dev/null || true)
    [ -z "$file" ] && { zenity --warning --text="No file selected. Capture cancelled."; return; }

    local cmd=""
    if [ "$captype" = "ble" ]; then
        local bmode
        bmode=$(zenity --list --title="BLE Capture Mode" \
            --column="Mode" --column="Description" \
            "adv"     "Advertisements only" \
            "follow"  "Follow specific connection (prompt for address)" \
            "prom"    "Promiscuous (all connections)" \
            2>/dev/null || true)
        [ -z "$bmode" ] && return

        cmd="ubertooth-btle"
        case "$bmode" in
            adv) cmd="$cmd -n" ;;
            follow)
                local taddr
                taddr=$(zenity --entry --title="Target (optional)" \
                    --text="Target address for follow (e.g. 22:44:66:88:aa:cc)\nLeave blank to follow any:" --entry-text="")
                cmd="$cmd -f"
                [ -n "$taddr" ] && cmd="$cmd -t '$taddr'"
                ;;
            prom) cmd="$cmd -p" ;;
        esac
    else
        # classic
        cmd="ubertooth-rx -z"   # survey-ish by default
        local lap
        lap=$(zenity --entry --title="LAP (optional)" --text="LAP (6 hex) - leave blank for all:" --entry-text="")
        if [ -n "$lap" ]; then
            cmd="ubertooth-rx -l $lap"
            local uap
            uap=$(zenity --entry --title="UAP (optional)" --text="UAP (2 hex):" --entry-text="")
            [ -n "$uap" ] && cmd="$cmd -u $uap"
        fi
    fi

    cmd="$cmd -r '$file'"
    launch_in_terminal "$cmd"
}

do_specan() {
    local lower upper
    lower=$(zenity --entry --title="Spectrum" --text="Lower frequency (MHz):" --entry-text="2402")
    upper=$(zenity --entry --title="Spectrum" --text="Upper frequency (MHz):" --entry-text="2480")
    [ -z "$lower" ] && lower=2402
    [ -z "$upper" ] && upper=2480

    local cmd="ubertooth-specan -l $lower -u $upper"
    if zenity --question --title="Gnuplot" --text="Generate output suitable for feedgnuplot (-g)?"; then
        cmd="$cmd -g"
    fi
    launch_in_terminal "$cmd"
}

do_led_specan() {
    local thresh
    thresh=$(zenity --entry --title="LED Spectrum" --text="RSSI threshold (higher = less sensitive, default 225):" --entry-text="225")
    [ -z "$thresh" ] && thresh=225
    launch_in_terminal "ubertooth-util -q $thresh"
}

do_afh() {
    local lap uap
    lap=$(zenity --entry --title="AFH Map" --text="LAP of target piconet (6 hex digits, e.g. 446688):" --entry-text="")
    uap=$(zenity --entry --title="AFH Map" --text="UAP of target piconet (2 hex digits, e.g. 22):" --entry-text="")
    if [ -z "$lap" ] || [ -z "$uap" ]; then
        zenity --warning --text="Both LAP and UAP are required."
        return
    fi
    launch_in_terminal "ubertooth-afh -l $lap -u $uap"
}

do_fix_gui() {
    if zenity --question --title="Install GUI Dependencies" \
        --text="This will install python3-qtpy and python3-pyside6 so that ubertooth-specan-ui (graphical spectrum analyzer) works.\n\nRun sudo apt install now?"; then
        launch_in_terminal "sudo apt update && sudo apt install -y python3-qtpy python3-pyside6"
        zenity --info --text="Installation complete. You can now try running 'ubertooth-specan-ui' from a terminal or the TUI menu."
    fi
}

do_launch_tui() {
    if command -v ubertooth-menu >/dev/null 2>&1; then
        /usr/share/kali-menu/exec-in-shell "ubertooth-menu" > /dev/null 2>&1 &
        zenity --info --text="Terminal-based menu (TUI) launched in a separate window."
    else
        zenity --warning --text="ubertooth-menu not found in PATH. Make sure it is installed (run the promotion script or type 'ubertooth-menu' directly)."
    fi
}

# Quick non-privileged awareness at launcher startup (no sudo, no blocking)
udev_count=$(ubertooth-util -N 2>/dev/null | tr -cd '0-9' || echo 0)
if [ "$udev_count" = "0" ]; then
    zenity --info --title="Ubertooth GUI - startup check" \
        --text="Ubertooth One not detected (count=0).\n\n• Make sure it is plugged in (USB).\n• For best results: launch 'Sniffer USB Manager' (Kali menu) and click 'Activate Ubertooth One' once.\n• Then return here and select the top '🚀 prepare' item.\n\nDevice count will appear in the menu title once ready.\n(This check does not run any privileged commands.)" \
        --timeout=7 --width=520 || true
fi

# Best-effort silent "bring up" of hci adapters at launcher start.
# Tries direct (if already capable) then sudo -n (non-interactive, succeeds only if
# passwordless sudoers was installed via Sniffer USB Manager full-setup or similar).
# Never prompts the user. Safe no-op otherwise. This is the "embedded at launch" bring-up.
for dev in $(hciconfig 2>/dev/null | grep -o '^hci[0-9]' | tr -d ':'); do
    if hciconfig "$dev" 2>/dev/null | grep -qi DOWN; then
        hciconfig "$dev" up 2>/dev/null || sudo -n hciconfig "$dev" up 2>/dev/null || true
    fi
    hciconfig "$dev" piscan 2>/dev/null || sudo -n hciconfig "$dev" piscan 2>/dev/null || true
done

# If still no UP adapter after silent attempt (no passwordless sudoers), do a graphical
# bring-up at launch time using pkexec. This pops a password dialog (if needed) right
# when you start the UTI, so the adapter is ready before you even pick "scan" from the menu.
# You don't have to hit "prepare" first for basic hci up.
if ! hciconfig 2>/dev/null | grep -qi 'UP'; then
    for d in $(hciconfig 2>/dev/null | grep -o '^hci[0-9]' | tr -d ':'); do
        if hciconfig "$d" 2>/dev/null | grep -qi DOWN; then
            if command -v pkexec >/dev/null 2>&1; then
                pkexec hciconfig "$d" up 2>/dev/null || true
            fi
            hciconfig "$d" piscan 2>/dev/null || sudo -n hciconfig "$d" piscan 2>/dev/null || true
            break
        fi
    done
fi

# Main menu loop
while true; do
    devcount=$(ubertooth-util -N 2>/dev/null | tr -cd '0-9' || echo 0)

    # Show current adapter status in the menu so you know if the auto bring-up at launch worked.
    # This addresses the case where you launch the UTI and immediately try scan without hitting prepare.
    adapter_status="hci: unknown"
    if hciconfig 2>/dev/null | grep -qi 'UP'; then
        adapter_status="hci adapter: UP"
    elif hciconfig 2>/dev/null | grep -qi 'DOWN'; then
        adapter_status="hci adapter: DOWN (tried auto-fix at launch + on scan)"
    else
        adapter_status="no classic hci adapter"
    fi

    choice=$(zenity --list --title="Ubertooth GUI (devices: ${devcount})" \
        --text="Point-and-click interface for common Ubertooth commands.\nUbertooth devices detected: ${devcount}\n${adapter_status}\n\nTIP: 'prepare' does full dongle prep (Sniffer mgr unbind). Adapter hci up is attempted automatically at launch and when picking scan." \
        --column="Action" --column="Description" \
        --width=620 --height=560 \
        "prepare"     "🚀 Prepare / bring up Ubertooth One + unbind drivers + hci adapters (recommended after plug-in)" \
        "status"      "Show firmware version, device info, LEDs status" \
        "identify"    "Blink all LEDs on the dongle (helps find it)" \
        "reset"       "Perform a full reset of the Ubertooth" \
        "scan"        "Classic Bluetooth scan (discover devices) — requires BT adapter (hci up)" \
        "ble_adv"     "BLE - passive advertisement listening" \
        "ble_follow"  "BLE - follow connections (with address prompts)" \
        "classic_rx"  "Classic RX / piconet survey / follow" \
        "capture"     "Capture packets to a PCAPNG file (BLE or Classic)" \
        "specan"      "2.4 GHz spectrum analyzer (text/gnuplot)" \
        "led_specan"  "Quick LED-based spectrum on the dongle itself" \
        "afh"         "Detect AFH channel map for a known piconet" \
        "fix_gui"     "Install packages needed for ubertooth-specan-ui (GUI spectrum)" \
        "tui"         "Launch the text/terminal menu (TUI) instead" \
        "quit"        "Close this graphical menu" \
        2>/dev/null || true)

    [ -z "$choice" ] && break   # cancelled or closed

    case "$choice" in
        prepare)     do_prepare ;;
        status)      show_status ;;
        identify)    do_identify ;;
        reset)       do_reset ;;
        scan)        do_scan ;;
        ble_adv)     do_ble_adv ;;
        ble_follow)  do_ble_follow ;;
        classic_rx)  do_classic_rx ;;
        capture)     do_capture ;;
        specan)      do_specan ;;
        led_specan)  do_led_specan ;;
        afh)         do_afh ;;
        fix_gui)     do_fix_gui ;;
        tui)         do_launch_tui ;;
        quit)        break ;;
        *)           zenity --warning --text="Unknown selection: $choice" ;;
    esac
done

exit 0
