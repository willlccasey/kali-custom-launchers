#!/usr/bin/env bash
#
# ocr-image
# Desktop-friendly tool: open/select a JPEG (or other image) with common text fonts
# and automatically copy the extracted text to the clipboard.
#
# Works great for standard printed text, screenshots, signs, documents, etc.

set -euo pipefail

# --- Dependency checks ---
if ! command -v tesseract >/dev/null 2>&1; then
    zenity --error --width=450 \
        --title="OCR - Missing tesseract" \
        --text="Tesseract OCR is not installed.\n\nInstall it with:\n\n  sudo apt install tesseract-ocr tesseract-ocr-eng\n\nThen try again." 2>/dev/null || true
    exit 1
fi

if ! command -v zenity >/dev/null 2>&1; then
    echo "Error: zenity is required (for file picker and text display)." >&2
    exit 1
fi

# --- Choose image ---
IMAGE=""
if [ $# -ge 1 ] && [ -f "$1" ]; then
    # Called with a file (e.g. "Open With" from file manager or desktop launcher)
    IMAGE="$1"
else
    # Launched normally → show file picker
    IMAGE=$(zenity --file-selection \
        --title="Select image to extract text from" \
        --file-filter="Images | *.jpg *.jpeg *.png *.tif *.tiff *.bmp *.webp" \
        --filename="$HOME/" 2>/dev/null || true)
fi

if [ -z "$IMAGE" ] || [ ! -f "$IMAGE" ]; then
    exit 0
fi

# --- Run OCR (tuned for common/standard fonts in pictures) ---
# -l eng     : English model (very good on common fonts)
# --psm 6    : Assume a single uniform block of text (excellent default for photos of text)
TEXT=$(tesseract "$IMAGE" stdout -l eng --psm 6 2>/dev/null | sed 's/[[:space:]]*$//')

if [ -z "$TEXT" ]; then
    notify-send "OCR" "No text detected in $(basename "$IMAGE")" --icon=dialog-warning 2>/dev/null || true
    zenity --info --title="OCR" --text="No readable text was found in the image." 2>/dev/null || true
    exit 0
fi

# --- Copy to clipboard (Wayland-aware) ---
COPIED=false
if [ -n "${WAYLAND_DISPLAY:-}" ] && command -v wl-copy >/dev/null 2>&1; then
    printf '%s' "$TEXT" | wl-copy && COPIED=true
elif command -v xclip >/dev/null 2>&1; then
    printf '%s' "$TEXT" | xclip -selection clipboard && COPIED=true
fi

# --- Notify + show result ---
FILENAME=$(basename "$IMAGE")

if $COPIED; then
    notify-send "Text copied to clipboard" "$FILENAME" --icon=edit-copy 2>/dev/null || true
else
    notify-send "OCR finished" "Could not auto-copy. Text shown below." --icon=dialog-warning 2>/dev/null || true
fi

# Show extracted text in a window (already copied, easy to review/select more)
TMPFILE=$(mktemp --tmpdir ocr-text.XXXXXX.txt)
printf '%s\n' "$TEXT" > "$TMPFILE"

zenity --text-info \
    --title="Extracted Text (already in clipboard) — $FILENAME" \
    --width=720 --height=480 \
    --filename="$TMPFILE" 2>/dev/null || true

rm -f "$TMPFILE"
